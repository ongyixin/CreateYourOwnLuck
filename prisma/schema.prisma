generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth required tables ──────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // App-specific fields
  role          Role      @default(USER)
  tier          Tier      @default(FREE)

  // Stripe subscription
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Admin-granted tier overrides
  tierGrantedBy String?
  tierExpiresAt DateTime?

  accounts  Account[]
  sessions  Session[]
  analyses  Analysis[]
  gtmPlans  GtmPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App-specific tables ───────────────────────────────────

model Analysis {
  id         String @id @default(cuid())
  userId     String
  jobId      String @unique
  company    String
  url        String
  status     String @default("pending")
  reportJson Json?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gtmPlans  GtmPlan[]
  createdAt DateTime  @default(now())
}

model GtmPlan {
  id         String     @id @default(cuid())
  analysisId String
  userId     String
  // generating | ready | approved | executing | complete | failed
  status     String     @default("generating")
  planJson   Json?
  editedJson Json?

  analysis  Analysis   @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets    GtmAsset[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model GtmAsset {
  id        String   @id @default(cuid())
  planId    String
  // messaging | creative | outreach | growth
  agent     String
  assetType String
  title     String
  content   Json
  // generating | complete | failed
  status    String   @default("generating")

  plan      GtmPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

enum Tier {
  FREE
  PRO
  AGENCY
}
