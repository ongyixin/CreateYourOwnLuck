# ── AI ─────────────────────────────────────────────────────
APIFY_TOKEN=apify_api_xxxxx
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GEMINI_API_KEY=xxxxx

# ── Database (Railway PostgreSQL add-on) ───────────────────
DATABASE_URL=postgresql://user:pass@host:5432/fitcheck

# ── Auth (NextAuth) ────────────────────────────────────────
NEXTAUTH_URL=https://your-domain.railway.app
NEXTAUTH_SECRET=                              # openssl rand -base64 32

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPx-xxxxx

# Resend (for email magic links: resend.com)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=FitCheck <noreply@yourdomain.com>

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx             # from Stripe Dashboard → Webhooks
STRIPE_PRO_PRICE_ID=price_xxxxx              # SERIES A recurring price ID
STRIPE_AGENCY_PRICE_ID=price_xxxxx          # SERIES B recurring price ID

# ── Admin ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
