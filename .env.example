# ── AI ─────────────────────────────────────────────────────
APIFY_TOKEN=apify_api_xxxxx
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GEMINI_API_KEY=xxxxx

# ── Database (Railway PostgreSQL add-on) ───────────────────
DATABASE_URL=postgresql://user:pass@host:5432/fitcheck

# ── Auth (NextAuth) ────────────────────────────────────────
NEXTAUTH_URL=https://your-domain.railway.app
NEXTAUTH_SECRET=                              # openssl rand -base64 32

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPx-xxxxx

# Resend (for email magic links: resend.com)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=FitCheck <noreply@yourdomain.com>

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx             # from Stripe Dashboard → Webhooks
STRIPE_PRO_PRICE_ID=price_xxxxx              # SERIES A recurring price ID
STRIPE_AGENCY_PRICE_ID=price_xxxxx          # SERIES B recurring price ID

# ── Admin ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com

# ── Social Publishing ───────────────────────────────────────
SOCIAL_TOKEN_SECRET=                          # openssl rand -base64 32 (used for AES-256-GCM token encryption)

# LinkedIn (LinkedIn Developer Portal → Apps → Products)
# Add: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn" (for posting)
# Scopes used: openid profile email w_member_social
# Redirect URI: {NEXTAUTH_URL}/api/social/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter / X (developer.twitter.com → Apps → Keys and Tokens)
# Scopes: tweet.read tweet.write users.read offline.access
# Redirect URI: {NEXTAUTH_URL}/api/social/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Facebook / Meta (developers.facebook.com → Apps → Facebook Login)
# Scopes: pages_manage_posts, pages_read_engagement, pages_show_list
# Redirect URI: {NEXTAUTH_URL}/api/social/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
